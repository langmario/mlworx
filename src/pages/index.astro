---
import Logo from "../assets/MLWX.svg";
import "../assets/global.css";
---

<html lang="de">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<meta name="generator" content={Astro.generator} />
		<title>ML WORX</title>
	</head>
	<body
		class="bg-[#05151a] text-white flex flex-col justify-center items-center gap-16 h-dvh"
	>
		<Logo class="shadow-effect fill-current mx-auto max-w-sm p-8" />
	</body>
</html>

<style>
	.shadow-effect {
		filter: drop-shadow(12px 12px 0px rgba(255 255 255 / 0.3))
			drop-shadow(12px 12px 0px rgba(255 255 255 / 0.3))
			drop-shadow(12px 12px 0px rgba(255 255 255 / 0.3));
	}
</style>
